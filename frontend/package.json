{
  "name": "classlens",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "node server.js",
    "build": "next build",
    "postbuild": "node scripts/postbuild.js",
    "start": "next start",
    "lint": "next lint",
    "electron": "electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && npm run postbuild && electron-builder",
    "electron:build:mac": "next build && npm run postbuild && electron-builder --mac",
    "electron:build:win": "next build && npm run postbuild && electron-builder --win",
    "electron:build:linux": "next build && npm run postbuild && electron-builder --linux"
  },
  "build": {
    "appId": "com.classlens.app",
    "productName": "ClassLens",
    "directories": {
      "output": "dist",
      "app": "."
    },
    "files": [
      "electron/**/*",
      ".next/standalone/**/*",
      ".next/static/**/*",
      "public/**/*",
      "package.json",
      "next.config.js",
      ".env.local"
    ],
    "asarUnpack": [
      ".next/**/*"
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.icns"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.ico"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Education",
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "assemblyai": "^4.23.0",
    "framer-motion": "^10.16.0",
    "groq-sdk": "^0.3.3",
    "lucide-react": "^0.294.0",
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-config-next": "^14.0.0",
    "fs-extra": "^11.2.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "typescript": "^5.3.0",
    "wait-on": "^7.2.0"
  }
}
